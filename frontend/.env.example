# ── Développement local ──────────────────────────────────────────────
# Copiez ce fichier en .env.local et utilisez ces valeurs en local :
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── Production (HeberFacile) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.enoteb.ma

# URL publique du site (canonical, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://enoteb.ma

# Ne pas définir PORT ici : Passenger l'injecte automatiquement
NODE_ENV=production
