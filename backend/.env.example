NODE_ENV=production
PORT=

# MySQL (format cPanel : utilisateur préfixé par le compte hébergement)
# Exemple : mysql://cpaneluser_enoteb:MOT_DE_PASSE@localhost:3306/cpaneluser_enoteb
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/enoteb"

# Seed initial (une seule fois après la première migration)
SEED_ADMIN_PASSWORD="change-me"

# Auth — générer des secrets longs et aléatoires (openssl rand -base64 48)
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# SMTP (compte email cPanel, voir DEPLOY.md)
SMTP_HOST="mail.enoteb.ma"
SMTP_PORT=587
SMTP_USER="contact@enoteb.ma"
SMTP_PASS="change-me"
CONTACT_EMAIL="contact@enoteb.ma"

# CORS — origine du frontend (prod)
CORS_ORIGIN="https://enoteb.ma"

# Upload — chemin absolu recommandé sur le serveur (hors public_html si possible)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
UPLOAD_IMAGE_MAX_WIDTH=1920
UPLOAD_IMAGE_MAX_HEIGHT=1920
UPLOAD_THUMBNAIL_WIDTH=640
UPLOAD_IMAGE_QUALITY=82
